		<title>training in the identification, handling and prevention of human rights abuses</title>
		<link>https://www.sodann.org/?p=129</link>
					<comments>https://www.sodann.org/?p=129#respond</comments>
		
		<dc:creator><![CDATA[sodadmin]]></dc:creator>
